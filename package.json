{
  "name": "sqlite-online",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "typecheck": "tsc -b",
    "build": "npm run typecheck && vite build",
    "preview": "vite preview",
    "build:pages": "npm run typecheck && vite build --mode pages",
    "preview:pages": "vite preview --mode pages",
    "deploy": "gh-pages -d dist",
    "check": "biome check .",
    "check:fix": "biome check --write .",
    "lint": "biome lint .",
    "lint:fix": "biome lint --write .",
    "format": "biome format --write .",
    "format:check": "biome check --formatter-enabled=true --linter-enabled=false --assist-enabled=false .",
    "knip": "knip",
    "doctor": "react-doctor . --verbose"
  },
  "knip": {
    "entry": [
      "src/main.tsx",
      "src/sqlite/sqliteWorker.ts"
    ],
    "ignore": [
      "src/types/window.d.ts"
    ]
  },
  "dependencies": {
    "@codemirror/autocomplete": "^6.18.6",
    "@codemirror/lang-sql": "^6.8.0",
    "@radix-ui/react-dialog": "^1.1.13",
    "@radix-ui/react-dropdown-menu": "^2.1.6",
    "@radix-ui/react-label": "^2.1.7",
    "@radix-ui/react-select": "^2.1.6",
    "@radix-ui/react-slot": "^1.1.2",
    "@radix-ui/react-tabs": "^1.1.3",
    "@tailwindcss/vite": "^4.0.9",
    "@types/lodash": "^4.17.16",
    "@uiw/codemirror-theme-darcula": "^4.23.10",
    "@uiw/react-codemirror": "^4.23.10",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "gh-pages": "^6.3.0",
    "lodash": "^4.17.23",
    "lucide-react": "^0.476.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-resizable-panels": "^2.1.7",
    "react-virtualized-auto-sizer": "^1.0.26",
    "react-window": "^1.8.11",
    "sonner": "^2.0.1",
    "sql.js": "^1.13.0",
    "tailwind-merge": "^3.2.0",
    "vite-plugin-compression": "^0.5.1",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.2.4",
    "@types/node": "^22.13.10",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.0.4",
    "@types/react-window": "^1.8.8",
    "@types/sql.js": "^1.4.9",
    "@vitejs/plugin-react": "^4.3.4",
    "babel-plugin-react-compiler": "^19.0.0-beta-e993439-20250328",
    "knip": "^5.52.0",
    "react-doctor": "^0.0.30",
    "typescript": "~5.7.2",
    "vite": "^6.4.1"
  }
}
